{
  "name": "karga-functions",
  "description": "Cloud Functions for Karga payment verification",
  "scripts": {
    "lint": "eslint .",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "migrate:ratings": "node scripts/migrate-ratings-schema.cjs",
    "migrate:support:dry": "node scripts/migrate-support-messages-to-conversations.cjs --project=karga-ph",
    "migrate:support:apply": "node scripts/migrate-support-messages-to-conversations.cjs --project=karga-ph --apply",
    "migrate:broker-role:dry": "node scripts/migrate-broker-primary-role.cjs",
    "migrate:broker-role:apply": "node scripts/migrate-broker-primary-role.cjs --apply",
    "migrate:email-auth:dry": "node scripts/reset-test-user-email-auth.cjs",
    "migrate:email-auth:apply": "node scripts/reset-test-user-email-auth.cjs --apply",
    "test:settings": "node scripts/settings-propagation-test.cjs",
    "test:referrals": "node scripts/referral-metrics-test.cjs",
    "test:referrals:integration": "firebase emulators:exec --only auth,firestore,functions \"node scripts/referral-listings-integration.cjs\"",
    "test:referrals:lifecycle": "firebase emulators:exec --only auth,firestore,functions \"node scripts/referral-lifecycle-integration.cjs\"",
    "test:referrals:reconcile": "firebase emulators:exec --only auth,firestore,functions \"node scripts/referral-commission-reconcile-integration.cjs\"",
    "test:platform-fee-reminders": "firebase emulators:exec --only auth,firestore,functions \"node scripts/platform-fee-reminders-smoke.cjs\"",
    "test": "npm run lint && node scripts/smoke-test.cjs && npm run test:settings",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "@google-cloud/vision": "^4.0.0",
    "axios": "^1.13.5",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.1.1",
    "imghash": "^1.1.2",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "firebase-functions-test": "^3.2.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.1"
  },
  "private": true
}
