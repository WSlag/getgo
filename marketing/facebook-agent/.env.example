# GetGo PH Facebook Marketing Agent — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Campaign Settings
DAILY_BUDGET_PHP=150
CAMPAIGN_START_DATE=2026-03-10
APP_NAME=GetGo PH
APP_URL=https://karga.ph
FACEBOOK_PAGE=@GetGoPH
TAGLINE=Karga. Trabaho. Tagumpay.

# Output settings
OUTPUT_DIR=./output
LANGUAGE=fil  # fil = Filipino/Tagalog, en = English, both = bilingual
