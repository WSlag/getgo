# Firebase Configuration (required - get from Firebase console)
# If these values are rotated, rebuild/redeploy the frontend.
# Ensure the API key allows Identity Toolkit + Firebase App Check APIs
# and your domains are authorized in Firebase Authentication.
# Site URL for canonical + social metadata (no trailing slash)
VITE_SITE_URL=https://your-domain.com
# Optional: canonical callback URL for Firebase email-link auth completion.
# Defaults to VITE_SITE_URL when omitted.
VITE_MAGIC_LINK_CALLBACK_URL=https://your-domain.com
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# GCash QR Code Image URL
VITE_GCASH_QR_URL=https://your-storage-url/Gcash.jpeg

# Firebase App Check
# Choose provider: auto | enterprise | v3 | off
# `auto` picks enterprise when VITE_RECAPTCHA_ENTERPRISE_KEY is set, otherwise v3.
VITE_APPCHECK_PROVIDER=auto
# Site key for the provider selected above
VITE_APPCHECK_SITE_KEY=your_recaptcha_site_key
# Backward compatibility: this legacy variable is also accepted
# VITE_RECAPTCHA_ENTERPRISE_KEY=your_recaptcha_enterprise_site_key
# Optional: set to false to disable App Check initialization on the client
# VITE_ENABLE_APPCHECK=true
# Optional: keep App Check disabled on localhost by default; set true to force enable it.
# VITE_ENABLE_APPCHECK_ON_LOCALHOST=false
# Optional: force debug token mode outside `npm run dev`
# VITE_APPCHECK_DEBUG=false

# Sentry Error Monitoring (optional - get DSN from sentry.io)
VITE_SENTRY_DSN=

# Optional: Cloud Functions region override (default: asia-southeast1)
VITE_FIREBASE_FUNCTIONS_REGION=asia-southeast1

# Optional: Enable email magic-link backup auth (phone remains primary)
# VITE_ENABLE_EMAIL_MAGIC_LINK=false

# Optional: Explicit route proxy endpoint (for custom hosting).
# Must point to your backend proxy function, not api.openrouteservice.org.
# VITE_ROUTE_PROXY_URL=https://asia-southeast1-your-project.cloudfunctions.net/getRoute
# VITE_GEOCODE_PROXY_URL=https://asia-southeast1-your-project.cloudfunctions.net/geocode
