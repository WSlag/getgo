{
  "name": "karga-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "E2E testing infrastructure for GetGo trucking marketplace",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:verify": "node tests/verify-setup.js",
    "test:smoke:gcash": "firebase emulators:exec --only auth,firestore,functions \"node functions/scripts/gcash-payment-smoke.cjs\"",
    "test:smoke:gcash:storage": "firebase emulators:exec --only auth,firestore,functions,storage \"node functions/scripts/gcash-payment-smoke.cjs --storage\"",
    "test:smoke:platform-fee-reminders": "firebase emulators:exec --only auth,firestore,functions \"node functions/scripts/platform-fee-reminders-smoke.cjs\"",
    "test:smoke:hosting:appcheck": "node scripts/smoke-hosting-appcheck.cjs",
    "test:smoke:hosting:fcm-runtime": "node scripts/smoke-hosting-fcm-runtime.cjs",
    "test:smoke:hosting:fcm-runtime:strict": "node scripts/smoke-hosting-fcm-runtime.cjs --strict-auth",
    "test:smoke:hosting:cache-headers": "node scripts/validate-hosting-cache-headers.cjs",
    "test:smoke:fcm:postdeploy:ci": "node scripts/validate-fcm-postdeploy.cjs --skip-build --skip-sdkconfig --runtime-check --runtime-skip-auth --base-url https://getgoph.com",
    "test:smoke:push:ci": "npm run test:smoke:fcm:postdeploy:ci && npm run test:smoke:hosting:cache-headers -- --base-url https://getgoph.com",
    "test:smoke:hosting:start-nav": "node scripts/smoke-hosting-startup-navigation.cjs",
    "test:smoke:hosting:no-debug-pages": "node scripts/smoke-hosting-no-debug-pages.cjs",
    "security:gate:baseline": "npm --prefix frontend run lint && npm --prefix frontend run build && npm --prefix functions test && npm run test:smoke:hosting:appcheck -- --skip-auth --timeout-ms 45000 --settle-ms 8000",
    "security:gate:auth-smoke": "npm run test:smoke:hosting:appcheck -- --timeout-ms 45000 --settle-ms 8000",
    "security:gate:staging": "npm run security:gate:baseline && npm run test:smoke:hosting:no-debug-pages -- --base-url https://getgoph.com",
    "emulators:start": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "validate:appcheck:prod": "node scripts/validate-frontend-appcheck.cjs frontend/.env.production",
    "validate:fcm:postdeploy": "node scripts/validate-fcm-postdeploy.cjs",
    "deploy:hosting:prod": "npm --prefix frontend run build && npm run validate:appcheck:prod && firebase deploy --only hosting:main --project getgoph-a09bb && npm run test:smoke:hosting:no-debug-pages -- --base-url https://getgoph.com && npm run test:smoke:hosting:cache-headers -- --base-url https://getgoph.com && npm run test:smoke:hosting:start-nav -- --url https://getgoph.com",
    "deploy:functions:prod": "firebase deploy --only functions --project karga-ph",
    "deploy:rules:prod": "firebase deploy --only firestore:rules,storage --project karga-ph",
    "deploy:firestore:prod": "firebase deploy --only firestore:rules,firestore:indexes --project karga-ph",
    "verify:firestore:support:prod": "node scripts/verify-firestore-support-config.cjs --project=karga-ph",
    "migrate:support:dry": "npm --prefix functions run migrate:support:dry",
    "migrate:support:apply": "npm --prefix functions run migrate:support:apply"
  },
  "keywords": ["testing", "e2e", "playwright", "firebase"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.41.0"
  }
}
